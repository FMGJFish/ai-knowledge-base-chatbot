# Environment Configuration
# Per technical_specification_v1.md — Configuration Management
#
# Copy this file to .env.local for local development.
# Never commit an actual .env or .env.local file — see .gitignore.
# Staging and Production values are managed as Vercel environment variables,
# scoped per environment per ADR Decision 013 (separate Supabase projects
# for Staging and Production).

# --- AI (OpenAI API) ---
# Used exclusively by the AI Response Service and Retrieval Service.
OPENAI_API_KEY=

# Chat-completion model identifier for the AI Response Service (Phase 6,
# Increment 1). Required -- no default value; the service fails immediately
# with a safe configuration error if this is unset. Distinct from, and does
# not resolve, the pre-existing hardcoded embedding-model constant in
# embedding.ts, which remains unchanged.
OPENAI_CHAT_MODEL=

# --- Supabase (PostgreSQL, Auth, Storage, pgvector) ---
# Distinct per environment per ADR Decision 013.
# Uses Supabase's current publishable/secret API key model (not the legacy
# anon/service_role JWT naming) to match the keys actually issued by the
# provisioned Staging and Production Supabase projects.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Administration ---
# Comma-separated list of Supabase Auth email addresses authorized as
# administrators (Implementation Roadmap Phase 3 correction). Any
# authenticated Supabase Auth identity whose email is not on this list is
# denied administrative access — fails closed if this is unset or empty.
# Server-only; never exposed to the browser (no NEXT_PUBLIC_ prefix).
# Shape: admin1@example.com,admin2@example.com
ADMIN_EMAIL_ALLOWLIST=

# --- Internal ---
# Shared secret for internal service-to-service calls (e.g., triggering
# asynchronous document processing per ADR Decision 004).
INTERNAL_SERVICE_SECRET=

# --- Upload Intent Continuity (Phase 4, Increment 1) ---
# Server-only signing secret for the Knowledge Processing Service's
# HMAC-signed upload-intent continuity token (direct-to-Supabase document
# upload). Distinct from INTERNAL_SERVICE_SECRET — a different trust
# context (this token is round-tripped through the browser; the signing
# secret itself never is). Never exposed to the browser (no NEXT_PUBLIC_
# prefix), never logged.
UPLOAD_INTENT_SIGNING_SECRET=
